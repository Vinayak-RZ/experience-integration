# Copy to repo root as `.env` (gitignored). Never commit secrets.

NODE_ENV=development

# Web (Next.js)
NEXT_PUBLIC_BFF_URL=http://localhost:3001

# Product BFF (packages/api) — not the public /v1 surface
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
REQUIRE_DATABASE=false
DATABASE_URL=postgres://stamped:stamped@127.0.0.1:5432/stamped_l6

# Worker (packages/worker)
# DATABASE_URL shared with API

BETTER_AUTH_SECRET=dev-only-stamped-l6-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3001
WEB_ORIGIN=http://localhost:3000
AUTH_TOKEN_TTL_SECONDS=3600

# Fake email (Mailpit) — Phase B auth invites
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=noreply@stamped.local
MAILPIT_UI=http://127.0.0.1:8025

# Upstream base URLs (server-side only; fixture mode until live contracts)
L5_BASE_URL=http://127.0.0.1:8105
L5_TIMEOUT_MS=5000
# L5_AUTH_TOKEN=
# Feature gates for OpenAPI gaps (see contracts/upstream/l5/SOURCE.md)
L5_FEATURE_ALARM_ACK=false
L5_FEATURE_ALARM_ESCALATE=false
L5_FEATURE_ALARM_UNSILENCE=false
L4_BASE_URL=http://127.0.0.1:8104
L4_TIMEOUT_MS=15000
# L4_AUTH_TOKEN=
L4_LIVE=false
L2_BASE_URL=http://127.0.0.1:8102
L2_TIMEOUT_MS=5000
# L2_SERVICE_KEY=
L2_FEATURE_LEDGER=false
L2_FEATURE_BASELINES=false
# Never set L2_DATABASE_URL in L6.

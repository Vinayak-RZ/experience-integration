{
  "name": "stamped-l6",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=22.14.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter './packages/*' dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "validate": "pnpm typecheck && pnpm test && pnpm build",
    "ci:local": "bash ./scripts/ci-local.sh",
    "contracts:check": "./external/scripts/contract-check.sh"
  }
}
